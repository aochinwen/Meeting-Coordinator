# ============================================================
# Meeting Coordinator — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# In Vercel, set these variables in: Settings > Environment Variables
# Scope each variable to the correct environment (Production / Preview / Development).
# ============================================================

# Supabase Project URL
# Found at: Supabase Dashboard > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon (public) Key
# Found at: Supabase Dashboard > Project Settings > API > Project API Keys > anon/public
# Safe to expose to the browser — protected by Row Level Security (RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
